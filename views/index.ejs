<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-6xl mx-auto px-4 py-10 flex-grow">
  <% if (typeof empresaDbError !== 'undefined' && empresaDbError) { %>
    <div class="rounded-lg border border-red-300 bg-red-50 text-red-900 px-4 py-3 text-sm space-y-2">
      <p class="font-semibold">No se pudo leer la tabla EMPRESA</p>
      <p class="font-mono text-xs opacity-90"><%= empresaDbError %></p>
      <p class="text-slate-700">
        Revise que MariaDB esté en marcha, que exista la base indicada en <code class="bg-white px-1 rounded">DB_NAME</code> del archivo <code class="bg-white px-1 rounded">.env</code>
        y que el usuario y contraseña sean correctos.
      </p>
    </div>
  <% } else if (!empresa) { %>
    <div class="rounded-lg border border-amber-300 bg-amber-50 text-amber-950 px-4 py-4 text-sm space-y-3">
      <p class="font-semibold">La tabla EMPRESA existe pero no tiene ninguna fila (o la base está vacía).</p>
      <p>Cargue los datos del modelo P1 ejecutando en una terminal:</p>
      <pre class="bg-white border border-amber-200 rounded p-3 text-xs overflow-x-auto font-mono text-slate-800">mysql -u root -p bookar_p1 &lt; sql/schema.sql</pre>
    </div>
  <% } else { %>

    <section class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-brand"><%= empresa.nombre %></h1>
      <p class="mt-2 text-slate-600 max-w-2xl mx-auto">Libros físicos con experiencias en Realidad Aumentada</p>
    </section>

    <div class="grid md:grid-cols-3 gap-6">
      <article class="bg-white rounded-xl shadow p-6 border border-slate-100">
        <h2 class="text-accent-brand font-semibold uppercase text-xs tracking-wider">Misión</h2>
        <p class="mt-3 text-slate-700 leading-relaxed"><%= empresa.mision %></p>
      </article>
      <article class="bg-white rounded-xl shadow p-6 border border-slate-100">
        <h2 class="text-accent-brand font-semibold uppercase text-xs tracking-wider">Visión</h2>
        <p class="mt-3 text-slate-700 leading-relaxed"><%= empresa.vision %></p>
      </article>
      <article class="bg-white rounded-xl shadow p-6 border border-slate-100 md:col-span-1">
        <h2 class="text-accent-brand font-semibold uppercase text-xs tracking-wider">Socios y alianzas</h2>
        <p class="mt-3 text-slate-700 leading-relaxed"><%= empresa.socios %></p>
      </article>
    </div>

    <div class="mt-10 flex justify-center">
      <a href="/catalogo" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent-brand hover:brightness-110 text-white font-semibold shadow">
        Ver catálogo
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <%# ── Equipo fundador ──────────────────────────────────────────────── %>
    <% if (typeof empleados !== 'undefined' && empleados.length > 0) { %>
    <section class="mt-16">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-brand">Nuestro equipo fundador</h2>
        <p class="mt-2 text-slate-500 text-sm">Las personas detrás de BookAR</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% empleados.forEach(function(emp) { %>
          <article class="bg-white rounded-2xl border border-slate-100 p-6 flex flex-col items-center text-center shadow-sm hover:shadow-md transition-shadow">
            <% if (emp.foto_url) { %>
              <img src="<%= emp.foto_url %>"
                   alt="<%= emp.nombre %> <%= emp.apellidos %>"
                   class="w-20 h-20 rounded-full object-cover shadow border-2 border-white mb-4" />
            <% } else { %>
              <div class="w-20 h-20 rounded-full bg-brand flex items-center justify-center text-white text-2xl font-bold shadow mb-4">
                <%= emp.nombre.charAt(0).toUpperCase() %><%= emp.apellidos.charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <h3 class="font-bold text-slate-800 leading-tight">
              <%= emp.nombre %> <%= emp.apellidos %>
            </h3>
            <span class="mt-1 inline-block text-xs font-semibold text-accent-brand bg-accent-brand/10 px-2 py-0.5 rounded-full">
              <%= emp.puesto %>
            </span>
            <% if (emp.bio) { %>
              <p class="mt-3 text-sm text-slate-500 leading-relaxed"><%= emp.bio %></p>
            <% } %>
          </article>
        <% }); %>
      </div>
    </section>
    <% } %>

  <% } %>
</main>

<%- include('partials/footer') %>
