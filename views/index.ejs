<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="flex-grow">

  <%# ── Error / empty states ─────────────────────────────────────────── %>
  <% if (typeof empresaDbError !== 'undefined' && empresaDbError) { %>
    <div class="max-w-4xl mx-auto px-4 py-10">
      <div class="rounded-lg border border-red-300 bg-red-50 text-red-900 px-4 py-3 text-sm space-y-2">
        <p class="font-semibold">No se pudo leer la tabla EMPRESA</p>
        <p class="font-mono text-xs opacity-90"><%= empresaDbError %></p>
        <p class="text-slate-700">
          Revise que MariaDB esté en marcha, que exista la base indicada en
          <code class="bg-white px-1 rounded">DB_NAME</code> del archivo
          <code class="bg-white px-1 rounded">.env</code>
          y que el usuario y contraseña sean correctos.
        </p>
      </div>
    </div>
  <% } else if (!empresa) { %>
    <div class="max-w-4xl mx-auto px-4 py-10">
      <div class="rounded-lg border border-amber-300 bg-amber-50 text-amber-950 px-4 py-4 text-sm space-y-3">
        <p class="font-semibold">La tabla EMPRESA existe pero no tiene ninguna fila.</p>
        <p>Cargue los datos ejecutando:</p>
        <pre class="bg-white border border-amber-200 rounded p-3 text-xs overflow-x-auto font-mono text-slate-800">mysql -u root -p bookar_p1 &lt; sql/schema.sql</pre>
      </div>
    </div>
  <% } else { %>

    <%# ── HERO ──────────────────────────────────────────────────────── %>
    <section class="bg-brand text-white">
      <div class="max-w-6xl mx-auto px-4 py-20 flex flex-col md:flex-row items-center gap-10">
        <div class="flex-1 text-center md:text-left space-y-5">
          <span class="inline-block bg-white/10 text-white/80 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">
            Realidad Aumentada · Educación
          </span>
          <h1 class="text-4xl md:text-5xl font-bold leading-tight">
            <%= empresa.nombre %>
          </h1>
          <p class="text-lg text-white/80 max-w-xl leading-relaxed">
            Libros físicos que cobran vida. Tecnología AR integrada para transformar el aula en una experiencia inmersiva.
          </p>
          <a href="/catalogo"
             class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-accent-brand hover:brightness-110 text-white font-semibold shadow-lg transition-all">
            Ver catálogo
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <%# Decorative visual %>
        <div class="flex-shrink-0 w-52 h-52 md:w-64 md:h-64 rounded-3xl bg-white/10 border border-white/20 flex items-center justify-center shadow-2xl">
          <img src="/logo-bookar.png" alt="BookAR logo"
               class="w-36 md:w-44 object-contain drop-shadow-lg" />
        </div>
      </div>
    </section>

    <%# ── MISIÓN & VISIÓN ────────────────────────────────────────────── %>
    <section class="bg-slate-50 py-16">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-center text-2xl font-bold text-brand mb-10">Quiénes somos</h2>

        <div class="grid md:grid-cols-2 gap-6">
          <%# Misión %>
          <article class="relative bg-white rounded-2xl shadow-sm border border-slate-100 p-8 overflow-hidden">
            <div class="absolute top-0 left-0 h-full w-1 bg-accent-brand rounded-l-2xl"></div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-full bg-accent-brand/10 flex items-center justify-center text-lg">🎯</div>
              <h3 class="font-bold text-accent-brand uppercase text-xs tracking-widest">Misión</h3>
            </div>
            <p class="text-slate-700 leading-relaxed"><%= empresa.mision %></p>
          </article>

          <%# Visión %>
          <article class="relative bg-white rounded-2xl shadow-sm border border-slate-100 p-8 overflow-hidden">
            <div class="absolute top-0 left-0 h-full w-1 bg-brand rounded-l-2xl"></div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 rounded-full bg-brand/10 flex items-center justify-center text-lg">🔭</div>
              <h3 class="font-bold text-brand uppercase text-xs tracking-widest">Visión</h3>
            </div>
            <p class="text-slate-700 leading-relaxed"><%= empresa.vision %></p>
          </article>
        </div>
      </div>
    </section>

    <%# ── EQUIPO ─────────────────────────────────────────────────────── %>
    <% if (typeof empleados !== 'undefined' && empleados.length > 0) { %>
    <section class="bg-white py-16">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-2xl font-bold text-brand">Nuestro equipo fundador</h2>
          <p class="mt-2 text-slate-500 text-sm">Las personas detrás de BookAR</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <% empleados.forEach(function(emp) { %>
            <article class="bg-slate-50 rounded-2xl border border-slate-100 p-6 flex flex-col items-center text-center shadow-sm hover:shadow-md transition-shadow">

              <%# Avatar: foto o iniciales %>
              <% if (emp.foto_url) { %>
                <img src="<%= emp.foto_url %>"
                     alt="<%= emp.nombre %> <%= emp.apellidos %>"
                     class="w-20 h-20 rounded-full object-cover shadow border-2 border-white mb-4" />
              <% } else { %>
                <div class="w-20 h-20 rounded-full bg-brand flex items-center justify-center text-white text-2xl font-bold shadow mb-4 border-2 border-white">
                  <%= emp.nombre.charAt(0).toUpperCase() %><%= emp.apellidos.charAt(0).toUpperCase() %>
                </div>
              <% } %>

              <h3 class="font-bold text-slate-800 leading-tight">
                <%= emp.nombre %> <%= emp.apellidos %>
              </h3>
              <span class="mt-1 inline-block text-xs font-semibold text-accent-brand bg-accent-brand/10 px-2 py-0.5 rounded-full">
                <%= emp.puesto %>
              </span>
              <% if (emp.bio) { %>
                <p class="mt-3 text-sm text-slate-500 leading-relaxed"><%= emp.bio %></p>
              <% } %>
            </article>
          <% }); %>
        </div>
      </div>
    </section>
    <% } %>

  <% } %>
</main>

<%- include('partials/footer') %>
