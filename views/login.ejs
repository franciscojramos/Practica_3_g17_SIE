<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-lg mx-auto px-4 py-12 flex-grow">
  <h1 class="text-2xl font-bold text-brand mb-6">Ingresar</h1>
  <% if (error) { %>
    <p class="mb-4 text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2"><%= error %></p>
  <% } %>
  <form action="/login" method="post" class="space-y-4 bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
    <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '/carrito' %>" />
    <div>
      <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
      <input id="email" name="email" type="email" required autocomplete="username"
        class="mt-1 w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
    </div>
    <div>
      <label for="password" class="block text-sm font-medium text-slate-700">Contraseña</label>
      <input id="password" name="password" type="password" required autocomplete="current-password"
        class="mt-1 w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" />
    </div>
    <button type="submit" class="w-full py-2.5 rounded-lg bg-brand hover:brightness-110 text-white font-semibold">
      Entrar
    </button>
  </form>
  <p class="mt-4 text-center text-sm text-slate-600">
    ¿No tiene cuenta? <a href="/registro" class="text-accent-brand font-semibold hover:underline">Registrarse</a>
  </p>
</main>

<%- include('partials/footer') %>
