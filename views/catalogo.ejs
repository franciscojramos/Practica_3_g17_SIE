<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-6xl mx-auto px-4 py-10 flex-grow">
  <h1 class="text-2xl font-bold text-brand mb-6">Catálogo</h1>

  <%# ── Buscador ──────────────────────────────────────────────────────── %>
  <form method="GET" action="/catalogo" class="flex flex-col sm:flex-row gap-3 mb-8">
    <div class="relative flex-1">
      <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
      </span>
      <input
        type="search"
        name="q"
        value="<%= filtroQ %>"
        placeholder="Buscar producto…"
        class="w-full pl-9 pr-4 py-2 rounded-lg border border-slate-300 text-sm focus:outline-none focus:ring-2 focus:border-transparent"
        style="--tw-ring-color: var(--color-primary);"
      />
    </div>

    <select name="asignatura"
            class="px-3 py-2 rounded-lg border border-slate-300 text-sm bg-white focus:outline-none focus:ring-2"
            style="--tw-ring-color: var(--color-primary);">
      <option value="">Todas las asignaturas</option>
      <% asignaturas.forEach(function(a) { %>
        <option value="<%= a %>" <%= filtroAsignatura === a ? 'selected' : '' %>><%= a %></option>
      <% }); %>
    </select>

    <button type="submit"
            class="px-5 py-2 rounded-lg bg-brand text-white text-sm font-semibold hover:brightness-110 transition-all">
      Buscar
    </button>

    <% if (filtroQ || filtroAsignatura) { %>
      <a href="/catalogo"
         class="px-4 py-2 rounded-lg border border-slate-300 text-sm text-slate-600 hover:bg-slate-100 transition-all flex items-center gap-1">
        ✕ Limpiar
      </a>
    <% } %>
  </form>

  <%# ── Resultados ─────────────────────────────────────────────────────── %>
  <% if (!productos.length) { %>
    <div class="text-center py-16 text-slate-500">
      <p class="text-4xl mb-3">🔍</p>
      <p class="font-medium">No se encontraron productos</p>
      <% if (filtroQ || filtroAsignatura) { %>
        <a href="/catalogo" class="mt-3 inline-block text-sm text-accent-brand hover:underline">Ver todo el catálogo</a>
      <% } %>
    </div>
  <% } else { %>
    <p class="text-xs text-slate-400 mb-4"><%= productos.length %> producto<%= productos.length !== 1 ? 's' : '' %></p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% productos.forEach(function (p) {
           const precio = Number(p.precio);
           const img = p.imagen_url ? p.imagen_url : null;
      %>
        <article class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
          <% if (img) { %>
            <div class="aspect-[4/3] bg-slate-100 overflow-hidden flex items-center justify-center">
              <img src="<%= img %>" alt="" class="max-h-48 w-full object-contain" loading="lazy" />
            </div>
          <% } %>
          <div class="p-5 flex flex-col flex-grow">
            <p class="text-[10px] text-slate-500 font-mono">GTIN <%= p.gtin %></p>
            <h2 class="font-semibold text-lg text-slate-900 mt-1"><%= p.nombre_producto %></h2>
            <% if (p.asignatura) { %>
              <p class="mt-1 text-xs text-accent-brand font-medium"><%= p.asignatura %></p>
            <% } %>
            <p class="mt-4 text-xl font-bold text-brand"><%= formatEur(precio) %></p>
            <p class="text-sm <%= p.stock_actual > 0 ? 'text-emerald-700' : 'text-red-600' %>">
              Stock: <%= p.stock_actual %>
            </p>
            <% if (p.stock_actual > 0) { %>
              <form action="/carrito/agregar" method="post" class="mt-4 flex gap-2 items-end">
                <input type="hidden" name="gtin" value="<%= p.gtin %>" />
                <label class="text-xs text-slate-500">
                  Cant.
                  <input type="number" name="cantidad" value="1" min="1" max="<%= p.stock_actual %>"
                         class="mt-1 w-20 border border-slate-300 rounded px-2 py-1 text-sm" />
                </label>
                <button type="submit"
                        class="flex-1 py-2 rounded-lg bg-accent-brand hover:brightness-110 text-white text-sm font-semibold">
                  Agregar
                </button>
              </form>
            <% } else { %>
              <p class="mt-4 text-sm text-slate-400">Sin stock</p>
            <% } %>
          </div>
        </article>
      <% }); %>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
