<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'BookAR' %></title>
  <style>
    :root {
      --color-primary: <%= brand.color_primario %>;
      --color-accent: <%= brand.color_secundario %>;
    }
    .bg-brand { background-color: var(--color-primary); }
    .text-brand { color: var(--color-primary); }
    .text-accent-brand { color: var(--color-accent); }
    .bg-accent-brand { background-color: var(--color-accent); }
    .border-brand { border-color: var(--color-primary); }
    .bg-brand-soft { background-color: rgba(0, 75, 122, 0.08); }
  </style>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 font-sans antialiased flex flex-col">
